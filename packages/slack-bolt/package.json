{
	"name": "@vercel/slack-bolt",
	"version": "1.2.1",
	"description": "A Vercel receiver for building Slack apps with Bolt and deploying them to Vercel",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "commonjs",
	"bin": {
		"vercel-slack": "./bin/vercel-slack.js"
	},
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.ts"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./preview": {
			"types": {
				"import": "./dist/preview.d.mts",
				"require": "./dist/preview.d.ts"
			},
			"import": "./dist/preview.mjs",
			"require": "./dist/preview.js"
		}
	},
	"typesVersions": {
		"*": {
			"preview": [
				"./dist/preview.d.ts"
			]
		}
	},
	"files": [
		"bin",
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/vercel-labs/slack-bolt"
	},
	"bugs": {
		"url": "https://github.com/vercel-labs/slack-bolt/issues"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"attw": "attw --pack ."
	},
	"keywords": [
		"vercel",
		"bolt",
		"slack"
	],
	"author": "Vercel",
	"license": "MIT",
	"dependencies": {
		"@slack/logger": "^4.0.0",
		"@vercel/functions": "^3.4.3",
		"commander": "^14.0.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@biomejs/biome": "2.2.2",
		"@types/node": "^20.19.35",
		"@vitest/coverage-v8": "4.0.18",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"@slack/bolt": "^4.4.0"
	},
	"peerDependenciesMeta": {
		"@slack/bolt": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
