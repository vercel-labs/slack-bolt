{
  "name": "@vercel/slack-bolt",
  "version": "1.5.1",
  "description": "A Vercel receiver for building Slack apps with Bolt and deploying them to Vercel",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "commonjs",
  "bin": {
    "vercel-slack": "./bin/vercel-slack.js"
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./preview": {
      "types": {
        "import": "./dist/preview.d.mts",
        "require": "./dist/preview.d.ts"
      },
      "import": "./dist/preview.mjs",
      "require": "./dist/preview.js"
    }
  },
  "typesVersions": {
    "*": {
      "preview": [
        "./dist/preview.d.ts"
      ]
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel-labs/slack-bolt"
  },
  "bugs": {
    "url": "https://github.com/vercel-labs/slack-bolt/issues"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "attw": "attw --pack ."
  },
  "keywords": [
    "vercel",
    "bolt",
    "slack"
  ],
  "author": "Vercel",
  "license": "MIT",
  "dependencies": {
    "@slack/logger": "^4.0.1",
    "@slack/oauth": "3.0.5",
    "@vercel/functions": "^3.6.1",
    "commander": "^14.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "2.4.16",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "tsdown": "^0.22.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@slack/bolt": "^4.4.0"
  },
  "peerDependenciesMeta": {
    "@slack/bolt": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
